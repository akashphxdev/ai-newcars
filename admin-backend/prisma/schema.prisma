  imageUrl       String?  @map("image_url") @db.VarChar(255)
  additionalCost Decimal? @map("additional_cost") @db.Decimal(8, 2)

  // A color can be a mix of 2+ shades ("dual tone" and beyond) — modeled
  // as a proper child table instead of a fixed isDualTone flag + single
  // colorHex, since the number of shades is now open-ended.
  shades CarColorShade[]
  images CarImage[]

  @@map("car_colors")
}

model CarColorShade {
  id        Int      @id @default(autoincrement())
  colorId   Int      @map("color_id")
