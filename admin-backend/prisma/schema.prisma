model NewCarOffer {
  id          Int         @id @default(autoincrement())
  modelId     Int         @map("model_id")
  model       CarModel    @relation(fields: [modelId], references: [id])
  variantId   Int?        @map("variant_id")
  variant     CarVariant? @relation(fields: [variantId], references: [id])
  cityId      Int?        @map("city_id")
  city        City?       @relation(fields: [cityId], references: [id])
  // Numeric code — frontend maps this to a label via
  // front/src/lib/lookups.ts's OFFER_TYPE_OPTIONS (1 = Cash discount,
  // 2 = Exchange bonus, ... 6 = Other). Backend only validates the code
  // is in range; it doesn't need to know the label text.
  offerType   Int?        @map("offer_type")
  offerAmount Decimal?    @map("offer_amount") @db.Decimal(10, 2)
  description String?     @db.VarChar(255)
  validFrom   DateTime?   @map("valid_from") @db.Date
  validUntil  DateTime?   @map("valid_until") @db.Date
  isActive    Boolean     @default(true) @map("is_active")
  // Required — same "image required on create" convention as Brand's
  // logoUrl / City's logoUrl.
  imageUrl    String      @map("image_url") @db.VarChar(255)

  @@map("new_car_offers")
}

