  colorHex  String   @map("color_hex") @db.VarChar(7)
  // Display order within the parent color (0, 1, 2...) — keeps a
  // multi-shade swatch rendering in the order the admin set it.
  sortOrder Int      @default(0) @map("sort_order")

  @@map("car_color_shades")
}

