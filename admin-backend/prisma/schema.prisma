// STORIES (editorial)
// ============================================================

model StoryCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)
  slug String @unique @db.VarChar(50)

  stories Story[]

  @@map("story_categories")
}

model Story {
  id              Int           @id @default(autoincrement())
  authorId        Int           @map("author_id")
  author          AdminUser     @relation(fields: [authorId], references: [id])
  categoryId      Int           @map("category_id")
  category        StoryCategory @relation(fields: [categoryId], references: [id])
  title           String        @db.VarChar(200)
  slug            String        @unique @db.VarChar(200)
  excerpt         String?       @db.VarChar(300)
  body            String?
  coverImageUrl   String?       @map("cover_image_url") @db.VarChar(255)
  readTimeMinutes Int?          @map("read_time_minutes")
  status          String        @default("draft") @db.VarChar(20)
  publishedAt     DateTime?     @map("published_at")
  viewCount       Int           @default(0) @map("view_count")
  createdAt       DateTime      @default(now()) @map("created_at")

  storyModels   StoryModel[]
  storyComments StoryComment[]

  @@map("stories")
}

model StoryModel {
  id      Int      @id @default(autoincrement())
  storyId Int      @map("story_id")
  story   Story    @relation(fields: [storyId], references: [id])
  modelId Int      @map("model_id")
  model   CarModel @relation(fields: [modelId], references: [id])

  @@map("story_models")
}

model StoryComment {
  id              Int            @id @default(autoincrement())
  storyId         Int            @map("story_id")
  story           Story          @relation(fields: [storyId], references: [id])
  userId          Int            @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  parentCommentId Int?           @map("parent_comment_id")
  parentComment   StoryComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         StoryComment[] @relation("CommentReplies")
  body            String
  status          String         @default("visible") @db.VarChar(20)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("story_comments")
}

