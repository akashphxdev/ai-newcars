// ============================================================
// TimesAuto — Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LOCATION
// ============================================================

model Country {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  code           String   @db.VarChar(5)
  currency       String?  @db.VarChar(50)
  currencySymbol String?  @map("currency_symbol") @db.VarChar(10)
  currencyCode   String?  @map("currency_code") @db.VarChar(10)
  exchangeRate   Decimal? @map("exchange_rate") @db.Decimal(12, 6)
  distanceUnit   String?  @default("KM") @map("distance_unit") @db.VarChar(10)
  fuelUnit       String?  @default("Liter") @map("fuel_unit") @db.VarChar(10)
  isActive       Boolean  @default(true) @map("is_active")

  states State[]
  brands Brand[]

  @@map("countries")
}

model State {
  id        Int        @id @default(autoincrement())
  countryId Int        @map("country_id")
  name      String     @db.VarChar(100)
  code      String?    @db.VarChar(10)
  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]

  @@map("states")
}

model District {
  id      Int    @id @default(autoincrement())
  stateId Int    @map("state_id")
  name    String @db.VarChar(100)
  state   State  @relation(fields: [stateId], references: [id])
  cities  City[]

  @@map("districts")
}

model City {
  id                Int      @id @default(autoincrement())
  districtId        Int      @map("district_id")
  name              String   @db.VarChar(100)
  slug              String   @unique @db.VarChar(100)
  isMetro           Boolean  @default(false) @map("is_metro")
  isTopCity         Boolean  @default(false) @map("is_top_city")
  isSellCarEnabled  Boolean  @default(false) @map("is_sell_car_enabled")
  logoUrl           String?  @map("logo_url") @db.VarChar(255)
  district          District @relation(fields: [districtId], references: [id])

  users           User[]
  usedCarListings UsedCarListing[]
  newCarOffers    NewCarOffer[]
  sellCarLeads    SellCarLead[]
  buyNewCarLeads  BuyNewCarLead[]
  insuranceLeads  InsuranceLead[]
  userAddresses   UserAddress[]

  @@map("cities")
}

// ============================================================
// SHARED LOOKUPS (used by new-car specs)
// ============================================================

model BodyType {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  iconUrl     String?  @map("icon_url") @db.VarChar(255)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  carModels CarModel[]

  @@map("body_types")
}

// Shared lookup table for small, fixed-choice vehicle attributes that are
// reused across multiple specs (transmission, drivetrain, and future ones
// like fuel-type) — one table instead of a separate one per attribute.
// `category` scopes each row (e.g. "transmission", "drivetrain"); the
// (category, slug) pair is what's actually unique, not slug alone, so two
// different categories are free to both have e.g. slug "standard" later.
model AttributeOption {
  id       Int    @id @default(autoincrement())
  category String @db.VarChar(30)
  name     String @db.VarChar(50)
  slug     String @db.VarChar(50)

  variantTransmissions CarVariant[]            @relation("VariantTransmission")
  iceTransmissionTypes CarPowertrainIce[]       @relation("IceTransmissionType")
  iceDrivetrains       CarPowertrainIce[]       @relation("IceDrivetrain")
  electricDrivetrains  CarPowertrainElectric[]  @relation("ElectricDrivetrain")

  @@unique([category, slug])
  @@map("attribute_options")
}

// ============================================================
// ADMIN
// ============================================================

model Role {
  id            Int      @id @default(autoincrement())
  roleName      String   @map("role_name") @db.VarChar(50)
  parentRoleId  Int?     @map("parent_role_id")
  parentRole    Role?    @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles    Role[]   @relation("RoleHierarchy")
  permissionIds Json?    @map("permission_ids")
  createdBy     Int?     @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  adminUsers AdminUser[]

  @@map("roles")
}

model Permission {
  id            Int    @id @default(autoincrement())
  module        String @db.VarChar(50)
  action        String @db.VarChar(20)
  permissionKey String @unique @map("permission_key") @db.VarChar(100)

  @@map("permissions")
}

model AdminUser {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(100)
  email               String    @unique @db.VarChar(150)
  mobile              String    @unique @db.VarChar(15)
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  roleId              Int       @map("role_id")
  role                Role      @relation(fields: [roleId], references: [id])
  status              String    @default("active") @db.VarChar(20)
  accessStartDate     DateTime? @map("access_start_date") @db.Date
  accessEndDate       DateTime? @map("access_end_date") @db.Date
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip") @db.VarChar(45)
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  isLocked            Boolean   @default(false) @map("is_locked")
  lockType            String?   @map("lock_type") @db.VarChar(20)
  lockedBy            Int?      @map("locked_by")
  lockedAt            DateTime? @map("locked_at")
  lockedReason        String?   @map("locked_reason") @db.VarChar(255)
  unlockedBy          Int?      @map("unlocked_by")
  unlockedAt          DateTime? @map("unlocked_at")
  createdBy           Int?      @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")

  lockedByAdmin   AdminUser? @relation("LockedByAdmin", fields: [lockedBy], references: [id])
  unlockedByAdmin AdminUser? @relation("UnlockedByAdmin", fields: [unlockedBy], references: [id])
  createdByAdmin  AdminUser? @relation("CreatedByAdmin", fields: [createdBy], references: [id])

  lockedAccounts   AdminUser[] @relation("LockedByAdmin")
  unlockedAccounts AdminUser[] @relation("UnlockedByAdmin")
  createdAccounts  AdminUser[] @relation("CreatedByAdmin")

  adminLogs             AdminLog[]
  adminOtpVerifications AdminOtpVerification[]
  deletedIcePowertrains CarPowertrainIce[]
  deletedEvPowertrains  CarPowertrainElectric[]
  leadActivities        LeadActivity[]
  seoMetaUpdates        SeoMeta[]
  seoRedirectsCreated   SeoRedirect[]

  // Articles — three separate relations to AdminUser (byline author,
  // who actually created the row, who last edited it) so each needs
  // its own relation name to disambiguate.
  articlesAuthored         Article[]         @relation("ArticleAuthor")
  articlesCreated          Article[]         @relation("ArticleCreatedBy")
  articlesUpdated          Article[]         @relation("ArticleUpdatedBy")
  articleCategoriesCreated ArticleCategory[] @relation("ArticleCategoryCreatedBy")
  articleCategoriesUpdated ArticleCategory[] @relation("ArticleCategoryUpdatedBy")

  // Stories — created/updated split into their own relation names,
  // same convention as ArticleCreatedBy/ArticleUpdatedBy above.
  storyGroupsCreated StoryGroup[] @relation("StoryGroupCreatedBy")
  storyGroupsUpdated StoryGroup[] @relation("StoryGroupUpdatedBy")
  storyItemsCreated  StoryItem[]  @relation("StoryItemCreatedBy")
  storyItemsUpdated  StoryItem[]  @relation("StoryItemUpdatedBy")

  @@map("admin_users")
}

model AdminLog {
  id          BigInt    @id @default(autoincrement())
  adminId     Int       @map("admin_id")
  admin       AdminUser @relation(fields: [adminId], references: [id])
  description String?   @db.VarChar(255)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("admin_logs")
}

model AdminOtpVerification {
  id         Int       @id @default(autoincrement())
  adminId    Int       @map("admin_id")
  admin      AdminUser @relation(fields: [adminId], references: [id])
  mobile     String    @db.VarChar(15)
  otpCode    String    @map("otp_code") @db.VarChar(6)
  purpose    String    @db.VarChar(20)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("admin_otp_verifications")
}

// ============================================================
// PUBLIC USERS
// ============================================================

model User {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(100)
  email               String?   @unique @db.VarChar(150)
  mobile              String    @unique @db.VarChar(15)
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  cityId              Int?      @map("city_id")
  city                City?     @relation(fields: [cityId], references: [id])
  isVerified          Boolean   @default(true) @map("is_verified")
  status              String    @default("active") @db.VarChar(20)
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  isLocked            Boolean   @default(false) @map("is_locked")
  lockedAt            DateTime? @map("locked_at")
  lockedReason        String?   @map("locked_reason") @db.VarChar(255)
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip") @db.VarChar(45)
  createdAt           DateTime  @default(now()) @map("created_at")

  usedCarListings     UsedCarListing[]
  sellCarLeads        SellCarLead[]
  buyNewCarLeads      BuyNewCarLead[]
  buyUsedCarLeads     BuyUsedCarLead[]
  insuranceLeads      InsuranceLead[]
  loanLeads           LoanLead[]
  softLeads           SoftLead[]
  priceDropAlertLeads PriceDropAlertLead[]
  reviews             Review[]
  reviewHelpfulVotes  ReviewHelpfulVote[]
  articleComments     ArticleComment[]
  mileageLogs         MileageLog[]
  adImpressions       AdImpression[]
  adClicks            AdClick[]
  notifications       Notification[]
  pageViews           PageView[]
  searchLogs          SearchLog[]
  userAddresses       UserAddress[]

  @@map("users")
}

model UserOtpVerification {
  id         Int       @id @default(autoincrement())
  mobile     String    @db.VarChar(15)
  otpCode    String    @map("otp_code") @db.VarChar(6)
  purpose    String    @db.VarChar(20)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("user_otp_verifications")
}

// ============================================================
// CARS — COMMON
// ============================================================

model Brand {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  slug            String   @unique @db.VarChar(100)
  logoUrl         String?  @map("logo_url") @db.VarChar(255)
  countryOriginId Int?     @map("country_origin_id")
  countryOrigin   Country? @relation(fields: [countryOriginId], references: [id])
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  carModels           CarModel[]
  sellCarLeads        SellCarLead[]
  buyNewCarLeads      BuyNewCarLead[]
  buyUsedCarLeads     BuyUsedCarLead[]
  insuranceLeads      InsuranceLead[]
  loanLeads           LoanLead[]
  softLeads           SoftLead[]
  priceDropAlertLeads PriceDropAlertLead[]
  articleBrands       ArticleBrand[]

  @@map("brands")
}

model CarModel {
  id                 Int       @id @default(autoincrement())
  brandId            Int       @map("brand_id")
  brand              Brand     @relation(fields: [brandId], references: [id])
  name               String    @db.VarChar(100)
  slug               String    @unique @db.VarChar(100)
  bodyTypeId         Int?      @map("body_type_id")
  bodyType           BodyType? @relation(fields: [bodyTypeId], references: [id])
  launchStatus       String    @default("available") @map("launch_status") @db.VarChar(20)
  expectedLaunchDate DateTime? @map("expected_launch_date") @db.Date
  priceMin           Decimal?  @map("price_min") @db.Decimal(12, 2)
  priceMax           Decimal?  @map("price_max") @db.Decimal(12, 2)
  ratingAvg          Decimal?  @map("rating_avg") @db.Decimal(3, 2)
  coverImageUrl      String?   @map("cover_image_url") @db.VarChar(255)
  createdAt          DateTime  @default(now()) @map("created_at")

  variants            CarVariant[]
  images              CarImage[]
  faqs                CarFaq[]
  videos              CarVideo[]
  colors              CarColor[]
  newCarOffers        NewCarOffer[]
  usedCarListings     UsedCarListing[]
  sellCarLeads        SellCarLead[]
  buyNewCarLeads      BuyNewCarLead[]
  buyUsedCarLeads     BuyUsedCarLead[]
  insuranceLeads      InsuranceLead[]
  loanLeads           LoanLead[]
  softLeads           SoftLead[]
  priceDropAlertLeads PriceDropAlertLead[]
  reviews             Review[]
  mileageLogs         MileageLog[]
  articleCarModels    ArticleCarModel[]

  @@map("car_models")
}

model CarVariant {
  id              Int      @id @default(autoincrement())
  modelId         Int      @map("model_id")
  model           CarModel @relation(fields: [modelId], references: [id])
  variantName     String   @map("variant_name") @db.VarChar(100)
  // Required end-to-end: DB, validation schema, and TS types all agree —
  // no more silent NULLs slipping in from outside the API.
  price           Decimal  @db.Decimal(12, 2)
  seatingCapacity Int      @map("seating_capacity")
  transmissionId  Int             @map("transmission_id")
  // onDelete is explicit Restrict now that the column is NOT NULL —
  // attributeOption.service.ts already pre-checks usage before allowing
  // a transmission option to be deleted, this is a DB-level backstop.
  transmission    AttributeOption @relation("VariantTransmission", fields: [transmissionId], references: [id], onDelete: Restrict)
  isTopSeller     Boolean  @default(false) @map("is_top_seller")
  createdAt       DateTime @default(now()) @map("created_at")

  icePowertrains      CarPowertrainIce[]
  electricPowertrains CarPowertrainElectric[]
  images              CarImage[]
  features            CarFeature[]
  newCarOffers        NewCarOffer[]
  usedCarListings     UsedCarListing[]
  reviews             Review[]

  // Prevents two identical variants ("SX(O) Turbo DCT" + "SX(O) Turbo DCT")
  // under the same car model. App layer also checks this first for a
  // friendly error message — see assertVariantNameUnique in variant.service.ts.
  @@unique([modelId, variantName])
  @@map("car_variants")
}

model CarPowertrainIce {
  id                  Int        @id @default(autoincrement())
  variantId           Int        @map("variant_id")
  variant             CarVariant @relation(fields: [variantId], references: [id])
  // Numeric code, not a string — see FUEL_TYPE_CODES in
  // powertrainIce.validation.ts. Frontend resolves it to a label via
  // lib/lookups.ts, same pattern as NewCarOffer.offerType.
  fuelType            Int        @map("fuel_type")
  fuelTypeSubCategory String?    @map("fuel_type_sub_category") @db.VarChar(30)
  fuelTankCapacity    Decimal?   @map("fuel_tank_capacity") @db.Decimal(5, 2)
  cngTankCapacity     Decimal?   @map("cng_tank_capacity") @db.Decimal(5, 2)
  kerbWeight          Int?       @map("kerb_weight")
  engineDisplacement  Decimal?   @map("engine_displacement") @db.Decimal(5, 2)
  cubicCapacity       Int?       @map("cubic_capacity")
  cylinders           Int?
  cylinderCapacity    Decimal?   @map("cylinder_capacity") @db.Decimal(6, 2)
  transmissionTypeId  Int?             @map("transmission_type_id")
  transmissionType    AttributeOption? @relation("IceTransmissionType", fields: [transmissionTypeId], references: [id])
  transmissionSubType String?    @map("transmission_sub_type") @db.VarChar(20)
  transmissionSpeed   Int?       @map("transmission_speed")
  numGears            Int?       @map("num_gears")
  isFourByFour        Boolean    @default(false) @map("is_four_by_four")
  drivetrainId        Int?             @map("drivetrain_id")
  drivetrain          AttributeOption? @relation("IceDrivetrain", fields: [drivetrainId], references: [id])
  powerPs             Int?       @map("power_ps")
  powerMinRpm         Int?       @map("power_min_rpm")
  powerMaxRpm         Int?       @map("power_max_rpm")
  powerWeight         Decimal?   @map("power_weight") @db.Decimal(6, 2)
  torqueNm            Int?       @map("torque_nm")
  torqueMinRpm        Int?       @map("torque_min_rpm")
  torqueMaxRpm        Int?       @map("torque_max_rpm")
  torqueWeight        Decimal?   @map("torque_weight") @db.Decimal(6, 2)
  claimedFe           Decimal?   @map("claimed_fe") @db.Decimal(5, 2)
  realWorldMileage    Decimal?   @map("real_world_mileage") @db.Decimal(5, 2)
  cityMileage         Decimal?   @map("city_mileage") @db.Decimal(5, 2)
  highwayMileage      Decimal?   @map("highway_mileage") @db.Decimal(5, 2)
  topSpeedKmph        Int?       @map("top_speed_kmph")
  topSpeedTimeSec     Decimal?   @map("top_speed_time_sec") @db.Decimal(5, 2)
  realWorldUrl        String?    @map("real_world_url") @db.VarChar(255)
  cityUrl             String?    @map("city_url") @db.VarChar(255)
  highwayUrl          String?    @map("highway_url") @db.VarChar(255)
  isDefault           Boolean    @default(false) @map("is_default")
  isDeleted           Boolean    @default(false) @map("is_deleted")
  deletedBy           Int?       @map("deleted_by")
  deletedByAdmin      AdminUser? @relation(fields: [deletedBy], references: [id])
  deletedAt           DateTime?  @map("deleted_at")
  expiresAt           DateTime?  @map("expires_at")
  createdAt           DateTime   @default(now()) @map("created_at")

  @@map("car_powertrains_ice")
}

model CarPowertrainElectric {
  id                      Int        @id @default(autoincrement())
  variantId               Int        @map("variant_id")
  variant                 CarVariant @relation(fields: [variantId], references: [id])
  numMotors               Int?       @map("num_motors")
  motorType               String?    @map("motor_type") @db.VarChar(50)
  batteryCapacity         Decimal?   @map("battery_capacity") @db.Decimal(6, 2)
  batteryChemistry        String?    @map("battery_chemistry") @db.VarChar(30)
  thermalManagementSystem String?    @map("thermal_management_system") @db.VarChar(50)
  drivetrainId            Int?             @map("drivetrain_id")
  drivetrain              AttributeOption? @relation("ElectricDrivetrain", fields: [drivetrainId], references: [id])
  powerPs                 Int?       @map("power_ps")
  torqueNm                Int?       @map("torque_nm")
  claimedRange            Int?       @map("claimed_range")
  realWorldRange          Int?       @map("real_world_range")
  // Numeric code, not a string — see TEST_CYCLE_TYPE_CODES in
  // powertrainElectric.validation.ts. Frontend resolves it to a label
  // via lib/lookups.ts, same pattern as NewCarOffer.offerType.
  testCycleType           Int?       @map("test_cycle_type")
  topSpeedKmph            Int?       @map("top_speed_kmph")
  topSpeedTimeSec         Decimal?   @map("top_speed_time_sec") @db.Decimal(5, 2)
  acChargingOutput        Decimal?   @map("ac_charging_output") @db.Decimal(5, 2)
  acChargingTime          Decimal?   @map("ac_charging_time") @db.Decimal(5, 2)
  chargerSizeAc3kwHours   Int?       @map("charger_size_ac_3kw_hours")
  chargerSizeAc7kwHours   Int?       @map("charger_size_ac_7kw_hours")
  chargerSizeAc11kwHours  Int?       @map("charger_size_ac_11kw_hours")
  chargerSizeAc22kwHours  Int?       @map("charger_size_ac_22kw_hours")
  dcChargingOutput        Decimal?   @map("dc_charging_output") @db.Decimal(5, 2)
  dcFastChargingTime      String?    @map("dc_fast_charging_time") @db.VarChar(50)
  powertrainBootspace     Int?       @map("powertrain_bootspace")
  batteryWarrantyKm       Int?       @map("battery_warranty_km")
  batteryWarrantyYears    Int?       @map("battery_warranty_years")
  motorWarrantyKm         Int?       @map("motor_warranty_km")
  motorWarrantyYears      Int?       @map("motor_warranty_years")
  standardWarrantyKm      String?    @map("standard_warranty_km") @db.VarChar(20)
  standardWarrantyYears   Int?       @map("standard_warranty_years")
  realWorldUrl            String?    @map("real_world_url") @db.VarChar(255)
  cityUrl                 String?    @map("city_url") @db.VarChar(255)
  highwayUrl              String?    @map("highway_url") @db.VarChar(255)
  isDefault               Boolean    @default(false) @map("is_default")
  isDeleted               Boolean    @default(false) @map("is_deleted")
  deletedBy               Int?       @map("deleted_by")
  deletedByAdmin          AdminUser? @relation(fields: [deletedBy], references: [id])
  deletedAt               DateTime?  @map("deleted_at")
  expiresAt               DateTime?  @map("expires_at")
  createdAt               DateTime   @default(now()) @map("created_at")

  @@map("car_powertrains_electric")
}

model CarImage {
  id        Int         @id @default(autoincrement())
  modelId   Int         @map("model_id")
  model     CarModel    @relation(fields: [modelId], references: [id])
  variantId Int?        @map("variant_id")
  variant   CarVariant? @relation(fields: [variantId], references: [id])
  // Optional tag: this image is a photo of one specific color option
  // (e.g. the red Swift's gallery shots) rather than a general model
  // photo. Same nullable-FK shape as variantId above.
  colorId   Int?        @map("color_id")
  color     CarColor?   @relation(fields: [colorId], references: [id])
  imageUrl  String      @map("image_url") @db.VarChar(255)
  isPrimary Boolean     @default(false) @map("is_primary")
  angle     String?     @db.VarChar(30)

  @@map("car_images")
}

model CarFeature {
  id                  Int        @id @default(autoincrement())
  variantId           Int        @map("variant_id")
  variant             CarVariant @relation(fields: [variantId], references: [id])
  airbagsCount        Int?       @map("airbags_count")
  absWithEbd          Boolean    @default(false) @map("abs_with_ebd")
  esc                 Boolean    @default(false)
  hillAssist          Boolean    @default(false) @map("hill_assist")
  rearParkingCamera   Boolean    @default(false) @map("rear_parking_camera")
  frontParkingSensors Boolean    @default(false) @map("front_parking_sensors")
  tpms                Boolean    @default(false)
  isofixMounts        Boolean    @default(false) @map("isofix_mounts")
  ncapRating          Decimal?   @map("ncap_rating") @db.Decimal(2, 1)
  sunroof             Boolean    @default(false)
  keylessEntry        Boolean    @default(false) @map("keyless_entry")
  pushButtonStart     Boolean    @default(false) @map("push_button_start")
  cruiseControl       Boolean    @default(false) @map("cruise_control")
  climateControl      Boolean    @default(false) @map("climate_control")
  rearAcVents         Boolean    @default(false) @map("rear_ac_vents")
  autoDimmingMirror   Boolean    @default(false) @map("auto_dimming_mirror")
  powerWindows        Boolean    @default(false) @map("power_windows")
  upholsteryType      String?    @map("upholstery_type") @db.VarChar(30)
  adjustableSeats     Boolean    @default(false) @map("adjustable_seats")
  ventilatedSeats     Boolean    @default(false) @map("ventilated_seats")
  rearArmrest         Boolean    @default(false) @map("rear_armrest")
  ledHeadlamps        Boolean    @default(false) @map("led_headlamps")
  ledDrls             Boolean    @default(false) @map("led_drls")
  alloyWheels         Boolean    @default(false) @map("alloy_wheels")
  roofRails           Boolean    @default(false) @map("roof_rails")
  fogLamps            Boolean    @default(false) @map("fog_lamps")
  touchscreenSizeInch Decimal?   @map("touchscreen_size_inch") @db.Decimal(3, 1)
  androidAuto         Boolean    @default(false) @map("android_auto")
  appleCarplay        Boolean    @default(false) @map("apple_carplay")
  connectedCarTech    Boolean    @default(false) @map("connected_car_tech")
  numberOfSpeakers    Int?       @map("number_of_speakers")
  wirelessCharging    Boolean    @default(false) @map("wireless_charging")
  extraFeatures       String?    @map("extra_features")
  createdAt           DateTime   @default(now()) @map("created_at")

  @@map("car_features")
}

model CarFaq {
  id           Int      @id @default(autoincrement())
  modelId      Int      @map("model_id")
  model        CarModel @relation(fields: [modelId], references: [id])
