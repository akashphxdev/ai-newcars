  ogImageUrl      String?    @map("og_image_url") @db.VarChar(255)
  robotsDirective String?    @map("robots_directive") @db.VarChar(50)
  schemaType      String?    @map("schema_type") @db.VarChar(50)
  updatedBy       Int?       @map("updated_by")
  updatedByAdmin  AdminUser? @relation(fields: [updatedBy], references: [id])
  updatedAt       DateTime   @default(now()) @map("updated_at")

  @@map("seo_meta")
}

model SeoRedirect {
  id             Int        @id @default(autoincrement())
  oldPath        String     @unique @map("old_path") @db.VarChar(255)
  newPath        String     @map("new_path") @db.VarChar(255)
  redirectType   Int        @default(301) @map("redirect_type")
  isActive       Boolean    @default(true) @map("is_active")
  createdBy      Int?       @map("created_by")
  createdByAdmin AdminUser? @relation(fields: [createdBy], references: [id])
  createdAt      DateTime   @default(now()) @map("created_at")

  @@map("seo_redirects")
}

model SitemapEntry {
  id              Int       @id @default(autoincrement())
  pageType        String    @map("page_type") @db.VarChar(30)
  pageId          Int?      @map("page_id")
  urlPath         String    @map("url_path") @db.VarChar(255)
  priority        Decimal?  @default(0.5) @db.Decimal(2, 1)
  changeFrequency String?   @map("change_frequency") @db.VarChar(20)
  isIncluded      Boolean   @default(true) @map("is_included")
  lastModified    DateTime? @map("last_modified")

  @@map("sitemap_entries")
}

// ============================================================
// USER ADDRESSES
// ============================================================

model UserAddress {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  addressType  String?  @map("address_type") @db.VarChar(20)
  addressLine1 String?  @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  cityId       Int      @map("city_id")
  city         City     @relation(fields: [cityId], references: [id])
  pincode      String?  @db.VarChar(10)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("user_addresses")
}

// ============================================================
// ARTICLES
// ============================================================

model ArticleCategory {
  id       Int      @id @default(autoincrement())
  name     String   @db.VarChar(50)
  slug     String   @unique @db.VarChar(50)
  isActive Boolean  @default(true) @map("is_active")

  createdBy      Int?       @map("created_by")
  createdByAdmin AdminUser? @relation("ArticleCategoryCreatedBy", fields: [createdBy], references: [id])
  updatedBy      Int?       @map("updated_by")
  updatedByAdmin AdminUser? @relation("ArticleCategoryUpdatedBy", fields: [updatedBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  articles Article[]

  @@map("article_categories")
}

model Article {
  id         Int             @id @default(autoincrement())
  categoryId Int             @map("category_id")
  category   ArticleCategory @relation(fields: [categoryId], references: [id])

  // Public byline — who this article is credited to. Editable via a
  // dropdown in the editor; defaults to the creating admin but can be
  // reassigned to any admin (e.g. an editor publishing under a senior
  // writer's name).
  authorId Int       @map("author_id")
  author   AdminUser @relation("ArticleAuthor", fields: [authorId], references: [id])

  // Pure audit trail — set automatically from the logged-in admin at
  // create/update time, never user-editable. Deliberately separate
  // from authorId, which the editor can freely reassign.
  createdBy      Int?       @map("created_by")
  createdByAdmin AdminUser? @relation("ArticleCreatedBy", fields: [createdBy], references: [id])
  updatedBy      Int?       @map("updated_by")
  updatedByAdmin AdminUser? @relation("ArticleUpdatedBy", fields: [updatedBy], references: [id])

  title           String    @db.VarChar(200)
  slug            String    @unique @db.VarChar(200)
  excerpt         String?   @db.VarChar(300)
  body            String?
  coverImageUrl   String?   @map("cover_image_url") @db.VarChar(255)
  readTimeMinutes Int?      @map("read_time_minutes")

  // draft | scheduled | published
  status      String    @default("draft") @db.VarChar(20)
  isActive    Boolean   @default(true) @map("is_active")
  // Future publish time set by the admin. A scheduler job flips status
  // to "published" and stamps publishedAt once this time arrives.
  scheduledAt DateTime? @map("scheduled_at")
  publishedAt DateTime? @map("published_at")
  viewCount   Int       @default(0) @map("view_count")

  // SEO — kept directly on the article rather than in the shared
  // SeoMeta table, by design. canonicalUrl is deliberately NOT stored:
  // slug is unique, so the canonical URL is always derivable as
  // `${SITE_BASE_URL}/articles/${slug}` — nothing to store or drift.
  metaTitle       String? @map("meta_title") @db.VarChar(160)
  metaDescription String? @map("meta_description") @db.VarChar(300)
  metaKeywords    String? @map("meta_keywords") @db.VarChar(255)
  ogImageUrl      String? @map("og_image_url") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  articleBrands    ArticleBrand[]
  articleCarModels ArticleCarModel[]
  articleComments  ArticleComment[]

  @@map("articles")
}

// Join table — an article can cover multiple brands (e.g. a
// comparison/roundup piece), so a single brandId column on Article
// wouldn't fit. Deleting a Brand that's still linked here should be
// blocked the same way brand.service.ts already blocks deletion when
// car models are linked.
model ArticleBrand {
  id        Int     @id @default(autoincrement())
  articleId Int     @map("article_id")
  article   Article @relation(fields: [articleId], references: [id])
  brandId   Int     @map("brand_id")
  brand     Brand   @relation(fields: [brandId], references: [id])

  @@unique([articleId, brandId])
  @@map("article_brands")
}

// Join table — same reasoning as ArticleBrand, but for car models.
model ArticleCarModel {
  id        Int      @id @default(autoincrement())
  articleId Int      @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id])
  modelId   Int      @map("model_id")
  model     CarModel @relation(fields: [modelId], references: [id])

  @@unique([articleId, modelId])
  @@map("article_car_models")
}

model ArticleComment {
  id        Int     @id @default(autoincrement())
  articleId Int     @map("article_id")
  article   Article @relation(fields: [articleId], references: [id])
  userId    Int     @map("user_id")
  user      User    @relation(fields: [userId], references: [id])

  parentCommentId Int?             @map("parent_comment_id")
  parentComment   ArticleComment?  @relation("ArticleCommentReplies", fields: [parentCommentId], references: [id])
  replies         ArticleComment[] @relation("ArticleCommentReplies")

  body String

  // visible | hidden | flagged — moderation state
  status    String   @default("visible") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("article_comments")
}

// ============================================================
// STORIES
// ============================================================

model StoryGroup {
  id        Int    @id @default(autoincrement())
  title     String @db.VarChar(100)

  coverMediaType String @map("cover_media_type") @db.VarChar(10)
  coverMediaUrl  String @map("cover_media_url") @db.VarChar(255)

  viewCount    Int     @default(0) @map("view_count")
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @map("display_order")

  createdBy Int?       @map("created_by")
  createdByAdmin AdminUser? @relation("StoryGroupCreatedBy", fields: [createdBy], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")
  updatedBy Int?       @map("updated_by")
  updatedByAdmin AdminUser? @relation("StoryGroupUpdatedBy", fields: [updatedBy], references: [id])
  updatedAt DateTime?  @updatedAt @map("updated_at")

  items StoryItem[]
  @@unique([displayOrder])
  @@map("story_groups")
}


model StoryItem {
  id      Int        @id @default(autoincrement())
  groupId Int        @map("group_id")
  group   StoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  mediaType String @map("media_type") @db.VarChar(10)
  mediaUrl  String @map("media_url") @db.VarChar(255)

  description String? @db.VarChar(300)

  link        String? @db.VarChar(255)

  viewCount    Int     @default(0) @map("view_count")
  status  String    @default("draft") @db.VarChar(10) @map("status")
  startAt DateTime? @map("start_at")
  endAt   DateTime? @map("end_at")
  displayOrder Int     @map("display_order")

  createdBy Int?       @map("created_by")
  createdByAdmin AdminUser? @relation("StoryItemCreatedBy", fields: [createdBy], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")
  updatedBy Int?       @map("updated_by")
  updatedByAdmin AdminUser? @relation("StoryItemUpdatedBy", fields: [updatedBy], references: [id])
  updatedAt DateTime?  @updatedAt @map("updated_at")
  @@unique([groupId, displayOrder])
  @@map("story_items")

}
