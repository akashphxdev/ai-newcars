NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:admin123@localhost:5432/timesauto?schema=public"

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# 64-char hex string (32 bytes) — generate with: openssl rand -hex 32
AI_SETTINGS_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string

CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173